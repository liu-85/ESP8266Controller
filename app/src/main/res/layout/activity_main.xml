<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray"
    tools:context=".ui.MainActivity">

    <!-- Top Status Bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:background="@color/colorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_connection_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/disconnected"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:gravity="start"/>

            <TextView
                android:id="@+id/tv_mode_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/joystick_mode"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:layout_marginEnd="16dp"/>

            <Button
                android:id="@+id/btn_settings"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/settings"
                android:textColor="@color/white"
                android:backgroundTint="@color/colorPrimaryDark"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Left Joystick (Throttle) -->
    <LinearLayout
        android:id="@+id/left_joystick_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/control_buttons_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/middle_controls"
        app:layout_constraintWidth_percent="0.35">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/throttle"
            android:textSize="18sp"
            android:textColor="@color/textDark"
            android:layout_marginBottom="8dp"/>

        <com.example.esp8266controller.joystick.JoystickView
            android:id="@+id/left_joystick"
            android:layout_width="160dp"
            android:layout_height="160dp"/>
    </LinearLayout>

    <!-- Middle Controls -->
    <LinearLayout
        android:id="@+id/middle_controls"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/control_buttons_layout"
        app:layout_constraintStart_toEndOf="@id/left_joystick_layout"
        app:layout_constraintEnd_toStartOf="@id/right_joystick_layout">

        <!-- Mode Switch -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="控制模式"
                android:textSize="16sp"
                android:textColor="@color/textDark"/>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_gyro_mode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textOff="@string/joystick_mode"
                android:textOn="@string/gyro_mode"
                android:checked="false"
                android:layout_marginTop="8dp"/>

            <Button
                android:id="@+id/btn_calibrate"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="@string/calibrate"
                android:textColor="@color/textLight"
                android:backgroundTint="@color/colorPrimaryDark"
                android:visibility="gone"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

        <!-- Servo Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="舵机控制"
                android:textSize="16sp"
                android:textColor="@color/textDark"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_servo_left"
                    android:layout_width="80dp"
                    android:layout_height="48dp"
                    android:text="@string/servo_left"
                    style="@style/ControlButton"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_servo_center"
                    android:layout_width="80dp"
                    android:layout_height="48dp"
                    android:text="@string/servo_center"
                    style="@style/ControlButton"
                    android:layout_marginEnd="4dp"/>

                <Button
                    android:id="@+id/btn_servo_right"
                    android:layout_width="80dp"
                    android:layout_height="48dp"
                    android:text="@string/servo_right"
                    style="@style/ControlButton"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Right Joystick (Steering) -->
    <LinearLayout
        android:id="@+id/right_joystick_layout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintBottom_toTopOf="@id/control_buttons_layout"
        app:layout_constraintStart_toEndOf="@id/middle_controls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.35">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/steering"
            android:textSize="18sp"
            android:textColor="@color/textDark"
            android:layout_marginBottom="8dp"/>

        <com.example.esp8266controller.joystick.JoystickView
            android:id="@+id/right_joystick"
            android:layout_width="160dp"
            android:layout_height="160dp"/>
    </LinearLayout>

    <!-- Bottom Control Buttons (Custom Switches) -->
    <LinearLayout
        android:id="@+id/control_buttons_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_margin="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btn_switch_1"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="灯光"
            android:layout_marginEnd="4dp"
            style="@style/ControlButton"/>

        <Button
            android:id="@+id/btn_switch_2"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="蜂鸣器"
            android:layout_marginEnd="4dp"
            style="@style/ControlButton"/>

        <Button
            android:id="@+id/btn_switch_3"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="开关3"
            android:layout_marginEnd="4dp"
            style="@style/ControlButton"/>

        <Button
            android:id="@+id/btn_switch_4"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="开关4"
            style="@style/ControlButton"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>