<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/v7rc_bg"
    tools:context=".ui.MainActivity">

    <!-- Top Control Bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#33000000"
        android:orientation="horizontal"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Connection Icons (Top Left) -->
        <LinearLayout
            android:id="@+id/connection_icons_layout"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:id="@+id/mainWifiIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_status"
                android:gravity="center"
                android:text="📶"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true"
                android:alpha="0.3"
                android:visibility="visible"/>
            <TextView
                android:id="@+id/mainBtIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_status"
                android:gravity="center"
                android:text="ᛒ"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true"
                android:alpha="0.3"
                android:layout_marginStart="8dp"
                android:visibility="visible"/>
        </LinearLayout>

        <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

        <!-- Top Right Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btn1" android:layout_width="wrap_content" android:layout_height="40dp" android:text="按键1" style="@style/V7RCActionButton" android:layout_marginEnd="8dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btn2" android:layout_width="wrap_content" android:layout_height="40dp" android:text="按键2" style="@style/V7RCActionButton" android:layout_marginEnd="8dp"/>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch1" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/switch1_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="开关1" android:textColor="@color/white" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:layout_marginEnd="8dp">
                <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch2" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                <TextView android:id="@+id/switch2_label" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="开关2" android:textColor="@color/white" android:textSize="10sp"/>
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btn3" android:layout_width="wrap_content" android:layout_height="40dp" android:text="按键3" style="@style/V7RCActionButton" android:layout_marginEnd="8dp"/>
            <androidx.appcompat.widget.AppCompatButton android:id="@+id/btn4" android:layout_width="wrap_content" android:layout_height="40dp" android:text="按键4" style="@style/V7RCActionButton" android:layout_marginEnd="8dp"/>

            <ImageButton
                android:id="@+id/openSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/v7rc_yellow"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Main Area -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_bar"
        app:layout_constraintBottom_toTopOf="@id/status_bar">

        <!-- Left Joystick -->
        <com.example.esp8266controller.joystick.JoystickView
            android:id="@+id/leftJoystick"
            android:layout_width="220dp"
            android:layout_height="220dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="40dp"/>

        <!-- Center Controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintStart_toEndOf="@id/leftJoystick"
            app:layout_constraintEnd_toStartOf="@id/rightJoystick"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/gyroToggle"
                android:layout_width="140dp"
                android:layout_height="wrap_content"
                android:text="陀螺仪: OFF"
                style="@style/V7RCActionButton"/>
        </LinearLayout>

        <!-- Right Joystick -->
        <com.example.esp8266controller.joystick.JoystickView
            android:id="@+id/rightJoystick"
            android:layout_width="220dp"
            android:layout_height="220dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginEnd="40dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Status Bar -->
    <TextView
        android:id="@+id/status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#33000000"
        android:padding="4dp"
        android:text="状态显示"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Compatibility Invisible Elements -->
    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <TextView android:id="@+id/tv_connection_status" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <TextView android:id="@+id/tv_mode_status" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <Button android:id="@+id/btn_settings" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <androidx.appcompat.widget.SwitchCompat android:id="@+id/switch_gyro_mode" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <Button android:id="@+id/btn_calibrate" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <Button android:id="@+id/btn_switch_1" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <Button android:id="@+id/btn_switch_2" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <Button android:id="@+id/btn_switch_3" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />
    <Button android:id="@+id/btn_switch_4" android:layout_width="0dp" android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
